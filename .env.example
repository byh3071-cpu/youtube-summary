# YouTube Data API v3 key (피드/라디오)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Gemini API key (AI 요약/인사이트)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini 모델 ID (미설정 시 models/gemini-2.5-flash, 404 시 models/gemini-flash-latest 폴백)
# GEMINI_MODEL_ID=models/gemini-2.5-flash

# Notion 그래프 쓰기(요한 브레인 동기화) — 기본 off, 서버 전용
# Notion 통합(integration) 토큰. 미설정 시 노션 동기화 액션이 거절된다.
# NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 1(또는 true)일 때만 트리플/인물/개념 DB 쓰기 활성화. 미설정=off (RESOURCE/SUMMARY 동기화는 그대로 동작).
# NOTION_WRITE_GRAPH=1

# Optional: server-to-server 재검증 호출 시 사용
REVALIDATE_SECRET=your_long_random_secret_here

# Supabase project (server-side)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase project (client-side, public)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# 주인(운영자) 이메일: 이 이메일로 로그인한 사용자는 플랜 제한 없이 전 기능 사용
# OWNER_EMAIL=your_email@gmail.com

# Stripe (Pro 구독 결제)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...  (Stripe Dashboard에서 Pro 월 구독 가격 ID)

# 사이트 URL (결제 성공/취소 리다이렉트, OAuth 콜백용)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# 병합 피드 최대 노출 개수 (50~2000, 미설정 시 500)
# MAX_MERGED_FEED_ITEMS=500

# --- 선택: Gemini 버스트 레이트 리받 (미설정 시 코드 기본값 사용)
# GEMINI_ACTIONS_PER_MINUTE=36
# GEMINI_ANON_ACTIONS_PER_MINUTE=24
# GEMINI_TREND_PER_HOUR_PER_IP=40

# 프로덕션에서만 /api/debug-youtube 를 켤 때 (기본: 비활성·404)
# ENABLE_DEBUG_YOUTUBE=true

# 프로덕션에서 /api/ops/status 조회 시 필요한 헤더 값
# OPS_STATUS_SECRET=replace_with_a_long_random_secret
